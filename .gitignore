# Do not ignore project code
!app/
!app/**/*.py

# Ensure critical project files are tracked
!README.md
!pyproject.toml
!requirements.txt

# Configuration files (but ignore .env)
!app/core/config.py
!app/database/mysql.py

# Data files directory
!数据文件/
!数据文件/**/*.md

# Do not ignore tests
!app/eval/
!app/eval/**/*.py
!app/scripts/
!app/scripts/**/*.py