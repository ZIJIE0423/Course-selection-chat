# 大模型配置（本地填写真实密钥，切勿提交 .env）
DASHSCOPE_API_KEY=

# 模型网关配置。start_demo.ps1 默认自动读取本地 .env；只有显式传入
# -Deterministic 时才禁用模型。请只在本地 .env 填写真实密钥，切勿提交。
# 示例（兼容 OpenAI 协议的供应商）：
# LLM_PROVIDER=qwen
# MODEL_NAME=<your-model-name>
# LLM_BASE_URL=<your-provider-compatible-endpoint>
# DASHSCOPE_API_KEY=<your-local-key>
LLM_PROVIDER=none
MODEL_NAME=
LLM_BASE_URL=
LLM_API_KEY_ENV=
ENABLE_REASONING=false

# 默认使用本地 SQLite；生产环境可替换为 MySQL 连接串。
MYSQL_URL=sqlite:///./course_db.sqlite

# 向量知识库目录
CHROMA_DB_PATH=./chroma_data

# 小程序/WeOUC 服务端推送课程快照时使用。
INTEGRATION_TOKEN=

# 历史课表上传与可选 OCR 服务。
MAX_HISTORY_UPLOAD_MB=10
HISTORY_OCR_ENDPOINT=
HISTORY_OCR_API_KEY=

# 第一阶段模块开关
FEATURE_COURSE_PLANNING=true
FEATURE_ACADEMIC_HISTORY=true
FEATURE_SCHEDULE_CONFLICT=false
FEATURE_COURSE_FEEDBACK=false
FEATURE_STUDENT_REVIEW_RAG=false

# 多个地址使用英文逗号分隔。仅配置已获授权或允许公开采集的页面。
CRAWL_NOTICE_URLS=
CRAWL_FORUM_URLS=
