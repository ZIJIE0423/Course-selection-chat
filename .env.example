# 大模型配置（本地填写真实密钥，切勿提交 .env）
DASHSCOPE_API_KEY=

# 模型网关配置。第一阶段可保持 LLM_PROVIDER=none，使用确定性需求解析。
LLM_PROVIDER=none
MODEL_NAME=
LLM_BASE_URL=
LLM_API_KEY_ENV=
ENABLE_REASONING=false

# 默认使用本地 SQLite；生产环境可替换为 MySQL 连接串。
MYSQL_URL=sqlite:///./course_db.sqlite

# 向量知识库目录
CHROMA_DB_PATH=./chroma_data

# 小程序/WeOUC 服务端推送课程快照时使用。
INTEGRATION_TOKEN=

# 历史课表上传与可选 OCR 服务。
MAX_HISTORY_UPLOAD_MB=10
HISTORY_OCR_ENDPOINT=
HISTORY_OCR_API_KEY=

# 第一阶段模块开关
FEATURE_COURSE_PLANNING=true
FEATURE_ACADEMIC_HISTORY=true
FEATURE_SCHEDULE_CONFLICT=false
FEATURE_COURSE_FEEDBACK=false
FEATURE_STUDENT_REVIEW_RAG=false

# 多个地址使用英文逗号分隔。仅配置已获授权或允许公开采集的页面。
CRAWL_NOTICE_URLS=
CRAWL_FORUM_URLS=
